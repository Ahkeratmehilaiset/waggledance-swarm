{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://waggledance.local/schemas/solver_candidate.schema.json",
  "title": "Solver candidate (U3 autonomous synthesis)",
  "description": "One free-form solver candidate generated by U3 from a curiosity gap. Cold-shadow-throttled per Prompt_1_Master §U3 calibration overload rule.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "state",
    "solver_name",
    "cell_id",
    "spec_or_code",
    "source_gap_ref",
    "no_runtime_mutation",
    "provenance"
  ],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "candidate_id": {"type": "string", "pattern": "^[a-f0-9]{12}$"},
    "state": {
      "type": "string",
      "enum": ["raw_candidate", "schema_valid", "static_valid",
               "test_valid", "shadow_only", "cold_solver",
               "review_ready", "approved", "archived", "rejected"]
    },
    "solver_name": {"type": "string"},
    "cell_id": {"type": "string"},
    "spec_or_code": {"type": "object"},
    "source_gap_ref": {"type": "string"},
    "no_runtime_mutation": {"type": "boolean", "const": true},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by", "branch_name", "base_commit_hash"],
      "properties": {
        "produced_by": {"type": "string"},
        "branch_name": {"type": "string"},
        "base_commit_hash": {"type": "string"},
        "pinned_input_manifest_sha256": {"type": "string"}
      }
    },
    "match_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "use_count": {"type": "integer", "minimum": 0},
    "shadow_observation_seconds": {"type": "integer", "minimum": 0}
  }
}
