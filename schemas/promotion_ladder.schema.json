{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://waggledance.local/schemas/promotion_ladder.schema.json",
  "title": "Promotion ladder transition record",
  "description": "Records one transition between promotion stages. NO automatic promotion to live runtime; NO bypasses; every stage requires explicit criteria.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "transition_id",
    "ir_id",
    "from_stage",
    "to_stage",
    "criteria_satisfied",
    "ts_iso",
    "no_runtime_auto_promotion",
    "no_bypass"
  ],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "transition_id": {"type": "string"},
    "ir_id": {"type": "string"},
    "from_stage": {"type": "string"},
    "to_stage": {"type": "string"},
    "criteria_satisfied": {
      "type": "array",
      "items": {"type": "string"}
    },
    "criteria_failed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "ts_iso": {"type": "string"},
    "human_approval_id": {"type": ["string", "null"]},
    "rollback_target_stage": {"type": ["string", "null"]},
    "no_runtime_auto_promotion": {"type": "boolean", "const": true},
    "no_bypass": {"type": "boolean", "const": true},
    "rationale": {"type": "string"}
  }
}
